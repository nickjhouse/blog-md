# ---------------------------------------------------------------------------
# Copy this file to ".env.local" and fill in real values.
# .env.local is gitignored — never commit real keys.
# ---------------------------------------------------------------------------

# Public Supabase config (safe to expose to the browser).
# Found in Supabase Dashboard -> Project Settings -> API Keys.
# The PUBLISHABLE key (sb_publishable_...) replaces the legacy "anon" key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# SECRET key (sb_secret_...): bypasses Row Level Security. Server only.
# Replaces the legacy "service_role" key. NEVER expose to the browser
# (it auto-rejects browser use). Used only inside /api/admin/* and /api/comment.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx

# The email address that should be granted admin (used by the seed SQL / docs).
ADMIN_EMAIL=your_email@domain.com

# Public site URL (used for share links, Open Graph, sitemap).
# Set to your real domain in production (e.g. https://example.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare Web Analytics beacon token (optional). When set, the analytics
# script loads. Get it from Cloudflare dashboard -> Web Analytics -> your site.
# Leave blank locally; set it in production.
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# Resend API (admin "new comment" email notifications). Optional —
# notifications are a silent no-op until all three are set. The API key is
# SEPARATE from the SMTP credential used for Supabase auth emails.
RESEND_API_KEY=
NOTIFY_FROM=noreply@yourdomain.com
NOTIFY_TO=you@yourdomain.com

# Resend Audience for newsletter signups. Optional — the footer
# signup form returns "not configured" until this is set (reuses RESEND_API_KEY).
# Resend dashboard -> Audiences -> your audience -> copy the ID.
RESEND_AUDIENCE_ID=

# Shared secret for the auto-newsletter cron endpoint. Only needed if
# you use future-dated posts with auto-send: /api/cron/newsletter rejects any
# request whose "Authorization: Bearer <CRON_SECRET>" header doesn't match.
# In production, set it as a Worker secret (npx wrangler secret put CRON_SECRET)
# AND in the Supabase pg_cron job. Generate one with: openssl rand -base64 32
# Leave blank unless you're testing the cron endpoint locally.
CRON_SECRET=

# Cloudflare Turnstile bot protection (optional). The whole feature is inert
# until these are set. Create a widget at Cloudflare dashboard -> Turnstile.
# SITE KEY is public and inlined client-side at BUILD time (set it as a Cloudflare
# *build* variable, like the analytics token — NOT a runtime secret).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# SECRET KEY verifies tokens server-side for your own forms (newsletter). Set it
# as a Worker RUNTIME secret: npx wrangler secret put TURNSTILE_SECRET_KEY
# (For the auth forms, the secret goes in the Supabase dashboard instead —
# Supabase performs that verification. See the "Bot protection — Turnstile"
# section of the README for the full setup.)
TURNSTILE_SECRET_KEY=

# Error monitoring (optional).
#  - Client errors: Sentry browser Loader Script. Inert until set. Get the URL
#    from Sentry -> your project -> Settings -> Client Keys (DSN) -> "Loader Script"
#    (looks like https://js.sentry-cdn.com/<publicKey>.min.js). Public + inlined
#    client-side, so set it as a Cloudflare *build* variable (like the site key).
#  - Server errors: emailed to NOTIFY_TO (above) via Resend, rate-limited. No
#    extra config beyond the existing NOTIFY_FROM / NOTIFY_TO / RESEND_API_KEY.
NEXT_PUBLIC_SENTRY_LOADER_URL=
